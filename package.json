{
  "name": "node-red-contrib-dyson-purelink",
  "version": "0.6.0",
  "description": "NodeRed dyson purelink Adapter",
  "contributors": [
    {
      "name": "Patrick Brunier",
      "email": "foss@brunier.nl"
    },
    {
      "name": "naimo84",
      "email": "git@neumann-benjamin.de"
    },
    {
      "name": "ajago"
    }
  ],
  "homepage": "https://github.com/pbrunier/node-red-contrib-dyson-purelink",
  "licenses": [
    {
      "type": "MIT",
      "url": "https://github.com/pbrunier/node-red-contrib-dyson-purelink/blob/master/LICENSE"
    }
  ],
  "keywords": [
    "node-red",
    "dyson",
    "purelink",
    "Smart Home",
    "home automation"
  ],
  "node-red": {
    "nodes": {
      "dyson-config": "dist/dyson-config.js",
      "dyson-link": "dist/dyson-link.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pbrunier/node-red-contrib-dyson-purelink"
  },
  "scripts": {
    "start": "gulp && node-red",
    "prepack": "gulp",
    "release": "release-it",
    "dev": "gulp develop",
    "build": "gulp"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint --edit"
    }
  },
  "funding": {
    "type": "paypal",
    "url": "https://paypal.me/pbrunier"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "bonjour": "3.5.0",
    "cloneextend": "0.0.3",
    "debug": "^4.3.4",
    "events": "^3.3.0",
    "https": "^1.0.0",
    "lodash": "^4.17.21",
    "mqtt": "4.3.7"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.195",
    "@types/node": "^16.11.7",
    "@types/node-red": "^0.20.3",
    "@types/request-promise-native": "^1.0.18",
    "commitlint": "^17.6.6",
    "gulp": "^4.0.2",
    "gulp-nodemon": "^2.5.0",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-typescript": "^5.0.1",
    "gulp-watch": "^5.0.1",
    "husky": "8.0.3",
    "nodemon": "^3.0.0",
    "release-it": "^16.1.0",
    "typescript": "^5.1.6"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release v${version}",
      "changelog": "npx auto-changelog --stdout --commit-limit false --unreleased --template https://raw.githubusercontent.com/release-it/release-it/master/templates/changelog-compact.hbs"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": false
    },
    "hooks": {
      "after:bump": "npx auto-changelog -p"
    }
  },
  "commitlint": {
    "format": {
      "helpUrl": "test"
    },
    "rules": {
      "body-leading-blank": [
        1,
        "always"
      ],
      "footer-leading-blank": [
        1,
        "always"
      ],
      "header-max-length": [
        2,
        "always",
        72
      ],
      "scope-case": [
        2,
        "always",
        "lower-case"
      ],
      "subject-case": [
        2,
        "never",
        [
          "sentence-case",
          "start-case",
          "pascal-case",
          "upper-case"
        ]
      ],
      "subject-empty": [
        2,
        "never"
      ],
      "subject-full-stop": [
        2,
        "never",
        "."
      ],
      "type-case": [
        2,
        "always",
        "lower-case"
      ],
      "type-empty": [
        2,
        "never"
      ],
      "type-enum": [
        2,
        "always",
        [
          "build",
          "chore",
          "ci",
          "docs",
          "feat",
          "fix",
          "perf",
          "refactor",
          "revert",
          "style",
          "test"
        ]
      ]
    }
  }
}
