{
  "name": "node-red-contrib-dyson-purelink",
  "version": "0.8.3",
  "description": "NodeRed dyson purelink Adapter",
  "contributors": [
    {
      "name": "Patrick Brunier",
      "email": "foss@brunier.nl"
    },
    {
      "name": "naimo84"
    },
    {
      "name": "ajago"
    }
  ],
  "homepage": "https://github.com/pbrunier/node-red-contrib-dyson-purelink",
  "license": "MIT",
  "keywords": [
    "node-red",
    "dyson",
    "purelink",
    "Smart Home",
    "home automation"
  ],
  "node-red": {
    "nodes": {
      "dyson-config": "dist/dyson-config.js",
      "dyson-link": "dist/dyson-link.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pbrunier/node-red-contrib-dyson-purelink"
  },
  "scripts": {
    "start": "gulp && node-red",
    "prepack": "gulp",
    "release": "release-it",
    "dev": "gulp develop",
    "build": "gulp"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint --edit"
    }
  },
  "funding": {
    "type": "paypal",
    "url": "https://paypal.me/pbrunier"
  },
  "dependencies": {
    "axios": "^1.6.3",
    "bonjour": "3.5.0",
    "cloneextend": "0.0.3",
    "debug": "^4.3.4",
    "events": "^3.3.0",
    "https": "^1.0.0",
    "lodash": "^4.17.21",
    "mqtt": "4.3.8"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.202",
    "@types/node": "^18.11.9",
    "@types/node-red": "^0.20.7",
    "@types/request-promise-native": "^1.0.21",
    "commitlint": "^18.4.3",
    "gulp": "^4.0.2",
    "gulp-nodemon": "^2.5.0",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-typescript": "^5.0.1",
    "gulp-watch": "^5.0.1",
    "husky": "8.0.3",
    "nodemon": "^3.0.2",
    "release-it": "^17.0.1",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "gulp-typescript": {
      "source-map": "0.7.4"
    }
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release v${version}",
      "changelog": "npx auto-changelog --stdout --commit-limit false --unreleased --template https://raw.githubusercontent.com/release-it/release-it/master/templates/changelog-compact.hbs"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": false
    },
    "hooks": {
      "after:bump": "npx auto-changelog -p"
    }
  },
  "commitlint": {
    "format": {
      "helpUrl": "test"
    },
    "rules": {
      "body-leading-blank": [
        1,
        "always"
      ],
      "footer-leading-blank": [
        1,
        "always"
      ],
      "header-max-length": [
        2,
        "always",
        72
      ],
      "scope-case": [
        2,
        "always",
        "lower-case"
      ],
      "subject-case": [
        2,
        "never",
        [
          "sentence-case",
          "start-case",
          "pascal-case",
          "upper-case"
        ]
      ],
      "subject-empty": [
        2,
        "never"
      ],
      "subject-full-stop": [
        2,
        "never",
        "."
      ],
      "type-case": [
        2,
        "always",
        "lower-case"
      ],
      "type-empty": [
        2,
        "never"
      ],
      "type-enum": [
        2,
        "always",
        [
          "build",
          "chore",
          "ci",
          "docs",
          "feat",
          "fix",
          "perf",
          "refactor",
          "revert",
          "style",
          "test"
        ]
      ]
    }
  }
}
